# =================================================================
# Database Configuration (PostgreSQL)
# =================================================================
# 推荐使用 Neon (https://neon.tech) 或其他 PostgreSQL 托管服务
# 格式: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/gamehub"

# =================================================================
# Redis Configuration (Upstash)
# =================================================================
# 用于缓存、播放计数、API 限流
# 免费套餐: 10K 命令/天
# 获取: https://console.upstash.com
UPSTASH_REDIS_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_TOKEN="your-redis-token"

# =================================================================
# Meilisearch Configuration (搜索引擎)
# =================================================================
# 用于游戏全文搜索（支持中文分词）
# 本地开发: docker run -p 7700:7700 getmeili/meilisearch
# 生产环境: Railway (https://railway.app) 一键部署
# 可选: 如未配置，将降级到 PostgreSQL LIKE 查询
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# =================================================================
# Cloudinary Configuration (图片 CDN)
# =================================================================
# 用于游戏缩略图、截图、分类图标存储
# 免费套餐: 25GB 存储 + 25GB 带宽/月
# 获取: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Cloudinary Upload Presets (需在控制台手动创建)
# 游戏缩略图: 400x300, webp, auto:good
# 游戏截图: 1280x720, webp, auto:best
# 分类图标: 128x128, png
CLOUDINARY_PRESET_THUMBNAIL="preset-game-thumbnails"
CLOUDINARY_PRESET_SCREENSHOT="preset-game-screenshots"
CLOUDINARY_PRESET_ICON="preset-category-icons"

# =================================================================
# Admin & Security
# =================================================================
# 管理员密码（生产环境务必修改为强密码）
ADMIN_PASSWORD="change-me-in-production"

# 后台 session HMAC 密钥（生产环境必须配置，建议 openssl rand -base64 32）
ADMIN_SESSION_SECRET="generate-a-random-session-secret-32-chars-min"

# Cron Job 密钥（用于 Vercel Cron Jobs 验证）
# 生成方式: openssl rand -base64 32
CRON_SECRET="generate-a-random-secret-32-chars-min"

# =================================================================
# Application URLs
# =================================================================
# 应用访问地址（用于生成绝对 URL）
# 本地开发保持默认；生产环境务必改为实际域名
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_SITE_URL="https://www.lumagamehub.com"
# SITE_URL="https://www.lumagamehub.com"

# =================================================================
# Analytics & Feedback
# =================================================================
# Google Analytics 4 only loads when a site-specific measurement ID is configured.
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=""

# Microsoft Clarity only loads after visitor consent.
# Use a site-specific key when this project has its own Clarity project.
NEXT_PUBLIC_GAMEHUB_CLARITY_PROJECT_ID=""

# Typeform feedback opens only when a form URL or form ID is configured.
# Prefer the full URL if you use custom Typeform share settings.
NEXT_PUBLIC_GAMEHUB_TYPEFORM_FORM_ID=""
# NEXT_PUBLIC_GAMEHUB_TYPEFORM_URL="https://form.typeform.com/to/your-form-id"
