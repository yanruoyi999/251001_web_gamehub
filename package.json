{
  "name": "game-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build && tsx scripts/patch-static-locale-html.ts",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "audit:prod": "pnpm audit --prod --audit-level=moderate",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit up:pg",
    "db:seed": "tsx db/seed.ts",
    "verify:services": "tsx scripts/verify-services.ts",
    "meilisearch:setup": "tsx scripts/meilisearch-setup.ts",
    "check:links": "tsx scripts/check-external-links.ts",
    "ops:growth": "tsx scripts/growth-metrics.ts",
    "ops:monitoring": "tsx scripts/monitoring-status.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "ops:status": "tsx scripts/ops-status.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@upstash/redis": "^1.31.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.2.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "meilisearch": "^0.38.0",
    "next": "15.5.18",
    "next-intl": "^4.9.2",
    "postgres": "^3.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/node": "^20",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.5.10",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "picomatch": "4.0.4",
      "postcss": "8.5.10"
    }
  }
}
